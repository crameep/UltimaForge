{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unchained",
  "version": "0.1.1",
  "identifier": "com.unchained.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Unchained",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "http://45.76.19.61/launcher/{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2QkIyQUQ1NkJDMTdGQjMKUldTemY4RnIxU3E3Tm5neVZ5WU8xOEdQRTNFcDVDTkh3SytYTWVrUjlTOU02NkhwRk5Td3lhWEUK",
      "dangerousInsecureTransportProtocol": true
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp",
        "installerHooks": "installer-assets/nsis-hooks.nsi",
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}